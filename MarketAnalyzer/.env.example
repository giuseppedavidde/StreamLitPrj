# MarketAnalyzer — Environment Variables
# Copy this file to .env and fill in your real keys.
# NEVER commit .env to version control!

# CoinGecko API key (free tier: https://www.coingecko.com/en/api)
COINGECKO_API_KEY=your_coingecko_api_key_here

# Optional — only needed if using external AI/LLM features
# GOOGLE_API_KEY=
# GROQ_API_KEY=
# OPENROUTER_API_KEY=
